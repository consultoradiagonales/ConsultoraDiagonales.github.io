<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consultora Diagonales - Consultoría de Datos Inteligente</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-blue: #3B82F6;
            --secondary-blue: #60A5FA;
            --light-blue: #DBEAFE;
            --gray-dark: #1F2937;
            --gray-medium: #6B7280;
            --gray-light: #F3F4F6;
            --white: #FFFFFF;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--gray-dark);
            line-height: 1.6;
            background-color: var(--white);
        }

        /* HEADER */
        header {
            background: var(--white);
            padding: 1rem 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary-blue);
            text-decoration: none;
        }

        nav {
            display: flex;
            gap: 2rem;
            align-items: center;
        }

        nav a {
            text-decoration: none;
            color: var(--gray-dark);
            font-weight: 500;
            transition: color 0.3s ease;
        }

        nav a:hover {
            color: var(--primary-blue);
        }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, var(--gray-dark) 0%, var(--gray-medium) 100%);
            color: var(--white);
            padding: 8rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(96, 165, 250, 0.15) 0%, transparent 50%);
            pointer-events: none;
            animation: gradientShift 8s ease-in-out infinite;
        }

        @keyframes gradientShift {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }

        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .hero-accent {
            display: inline-block;
            width: 150px;
            height: 4px;
            background: var(--primary-blue);
            margin: 1.5rem 0;
            border-radius: 2px;
        }

        .hero p {
            font-size: 1.2rem;
            color: #E5E7EB;
            margin-bottom: 2rem;
            line-height: 1.8;
        }

        .cta-button {
            display: inline-block;
            background: var(--primary-blue);
            color: var(--white);
            padding: 1rem 2.5rem;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1rem;
        }

        .cta-button:hover {
            background: var(--secondary-blue);
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
        }

        .cta-button:active {
            transform: translateY(-1px);
        }

        /* SERVICES SECTION */
        .services {
            padding: 5rem 2rem;
            background: var(--gray-light);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: var(--gray-dark);
            font-weight: 700;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
        }

        .service-card {
            background: var(--white);
            padding: 2.5rem;
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            border-top: 4px solid var(--primary-blue);
            animation: fadeInUp 0.6s ease-out backwards;
        }

        .service-card:nth-child(1) { animation-delay: 0.1s; }
        .service-card:nth-child(2) { animation-delay: 0.2s; }
        .service-card:nth-child(3) { animation-delay: 0.3s; }
        .service-card:nth-child(4) { animation-delay: 0.4s; }
        .service-card:nth-child(5) { animation-delay: 0.5s; }
        .service-card:nth-child(6) { animation-delay: 0.6s; }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px rgba(59, 130, 246, 0.2);
        }

        .service-card h3 {
            color: var(--primary-blue);
            font-size: 1.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .service-card p {
            color: var(--gray-medium);
            line-height: 1.8;
        }

        /* TESTIMONIALS SECTION */
        .testimonials {
            padding: 5rem 2rem;
            background: var(--white);
        }

        .testimonials-container {
            max-width: 900px;
            margin: 0 auto;
            background: linear-gradient(135deg, var(--light-blue) 0%, var(--gray-light) 100%);
            padding: 3rem;
            border-radius: 12px;
            border-left: 5px solid var(--primary-blue);
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
        }

        .testimonial-text {
            font-size: 1.1rem;
            color: var(--gray-dark);
            margin-bottom: 1.5rem;
            font-style: italic;
            line-height: 1.8;
        }

        .testimonial-author {
            color: var(--primary-blue);
            font-weight: 600;
            text-align: right;
        }

        /* STATS SECTION */
        .stats {
            padding: 5rem 2rem;
            background: var(--gray-dark);
            color: var(--white);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            text-align: center;
        }

        .stat-item h4 {
            font-size: 2.5rem;
            color: var(--primary-blue);
            margin-bottom: 0.5rem;
            font-weight: 700;
        }

        .stat-item p {
            color: #D1D5DB;
            font-weight: 500;
        }

        /* FOOTER */
        footer {
            background: #111827;
            color: var(--white);
            padding: 3rem 2rem;
            text-align: center;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
        }

        footer h3 {
            font-size: 1.5rem;
            color: var(--primary-blue);
            margin-bottom: 1.5rem;
        }

        .footer-links {
            margin-bottom: 2rem;
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--secondary-blue);
            text-decoration: none;
            transition: color 0.3s ease;
            font-weight: 500;
        }

        .footer-links a:hover {
            color: var(--white);
        }

        .footer-bottom {
            border-top: 1px solid #374151;
            padding-top: 2rem;
            color: #9CA3AF;
        }

        /* ANIMATIONS */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.2rem;
            }

            .section-title {
                font-size: 1.8rem;
                margin-bottom: 2rem;
            }

            nav {
                gap: 1rem;
                font-size: 0.9rem;
            }

            .hero {
                padding: 4rem 2rem;
            }

            .services, .testimonials, .stats {
                padding: 3rem 2rem;
            }

            .footer-links {
                gap: 1rem;
                flex-direction: column;
            }
        }

        @media (max-width: 480px) {
            .logo {
                font-size: 1.4rem;
            }

            .hero h1 {
                font-size: 1.8rem;
            }

            nav {
                gap: 0.5rem;
                font-size: 0.8rem;
            }

            .section-title {
                font-size: 1.5rem;
            }

            .service-card h3 {
                font-size: 1.2rem;
            }

            .stat-item h4 {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
